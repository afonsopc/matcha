<%- include('partials/head') %>
<section class="panel">
  <div class="panel-header">
    <div>
      <h1 style="margin:0;">Suggested for you</h1>
      <p>Profiles ranked by location, shared interests, and fame</p>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <p class="hint"><%= profiles.length %> profile<%= profiles.length === 1 ? '' : 's' %></p>
      <a class="button ghost small" href="/search">Search &rarr;</a>
    </div>
  </div>
</section>

<% if (!profiles.length) { %>
  <section class="empty" style="margin-top:18px;">
    <strong>No suggestions yet.</strong>
    Complete your profile and add interests to get matched with others.
  </section>
<% } else { %>
  <section class="cards">
    <% profiles.forEach(p => { %>
      <article class="card">
        <a href="/users/<%= p.username %>">
          <div class="media">
            <% if (p.profile_photo) { %>
              <img src="/static/uploads/<%= p.profile_photo %>" alt="">
            <% } else { %>
              <div class="placeholder">No photo</div>
            <% } %>
            <div class="card-overlay">
              <h2><%= p.first_name %><%= p.age ? ', ' + p.age : '' %></h2>
              <p><span class="online-dot <%= p.online ? 'live' : '' %>"></span><%= p.city || 'Unknown city' %><%= p.distance !== null ? ' · ' + formatDistance(p.distance) : '' %></p>
            </div>
          </div>
          <div class="card-body">
            <p>
              <span class="fame-pill">★ <%= p.fame %></span>
              <% if (p.common_tags) { %><span class="tag-mini"><%= p.common_tags %> shared tag<%= p.common_tags === 1 ? '' : 's' %></span><% } %>
            </p>
          </div>
        </a>
      </article>
    <% }) %>
  </section>
<% } %>
<%- include('partials/foot') %>
