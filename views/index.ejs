<%- include('partials/head') %>
<section class="hero">
  <div>
    <p class="eyebrow">42 · Matcha</p>
    <h1>People worth meeting are closer than you think.</h1>
    <p>Build your profile, browse profiles ranked by what you share, like the ones you mean it for, and chat the moment it’s mutual.</p>
    <div class="actions">
      <a class="button primary" href="/register">Create an account</a>
      <a class="button" href="/login">I already have one</a>
    </div>
    <div class="feature-row">
      <div class="feature">
        <h3>Real matching</h3>
        <p>Profiles are sorted by location, shared tags, and fame — not a coin toss.</p>
      </div>
      <div class="feature">
        <h3>Mutual or nothing</h3>
        <p>Chat opens only when both sides liked each other’s pictures.</p>
      </div>
      <div class="feature">
        <h3>You stay in control</h3>
        <p>Block, report, unlike, and see exactly who has viewed you.</p>
      </div>
    </div>
  </div>
</section>
<%- include('partials/foot') %>
