<%- include('partials/head') %>
<section class="panel">
  <div class="panel-header">
    <div>
      <h1 style="margin:0;">Search profiles</h1>
      <p>Filter by age, location, fame, or interest</p>
    </div>
    <% if (profiles !== null) { %>
      <p class="hint"><%= profiles.length %> result<%= profiles.length === 1 ? '' : 's' %></p>
    <% } %>
  </div>
  <form method="get" class="filters">
    <label>Min age <input name="minAge" type="number" min="18" max="120" placeholder="18" value="<%= query.minAge || '' %>"></label>
    <label>Max age <input name="maxAge" type="number" min="18" max="120" placeholder="99" value="<%= query.maxAge || '' %>"></label>
    <label>Min fame <input name="minFame" type="number" min="0" max="100" placeholder="0" value="<%= query.minFame || '' %>"></label>
    <label>Max fame <input name="maxFame" type="number" min="0" max="100" placeholder="100" value="<%= query.maxFame || '' %>"></label>
    <label>Location <input name="location" placeholder="City or neighborhood" value="<%= query.location || '' %>"></label>
    <label>Tag <input name="tag" placeholder="e.g. coffee" value="<%= query.tag || '' %>"></label>
    <label>Sort by
      <select name="sort">
        <% [['','Best match'],['age','Age'],['location','Location'],['fame','Fame'],['tags','Common tags']].forEach(([v,l]) => { %>
          <option value="<%= v %>" <%= (query.sort || '') === v ? 'selected' : '' %>><%= l %></option>
        <% }) %>
      </select>
    </label>
    <div class="row-actions">
      <a class="button ghost small" href="/search">Clear filters</a>
      <button class="primary" type="submit">Search</button>
    </div>
  </form>
</section>

<% if (profiles === null) { %>
  <section class="empty" style="margin-top:18px;">
    Use the filters above to find specific profiles, or <a href="/browse">browse suggestions</a> instead.
  </section>
<% } else if (!profiles.length) { %>
  <section class="empty" style="margin-top:18px;">
    <strong>No profiles match those filters.</strong>
    Try widening the age range, removing the tag, or clearing the location.
  </section>
<% } else { %>
  <section class="cards">
    <% profiles.forEach(p => { %>
      <article class="card">
        <a href="/users/<%= p.username %>">
          <div class="media">
            <% if (p.profile_photo) { %>
              <img src="/static/uploads/<%= p.profile_photo %>" alt="">
            <% } else { %>
              <div class="placeholder">No photo</div>
            <% } %>
            <div class="card-overlay">
              <h2><%= p.first_name %><%= p.age ? ', ' + p.age : '' %></h2>
              <p><span class="online-dot <%= p.online ? 'live' : '' %>"></span><%= p.city || 'Unknown city' %><%= p.distance !== null ? ' · ' + formatDistance(p.distance) : '' %></p>
            </div>
          </div>
          <div class="card-body">
            <p>
              <span class="fame-pill">★ <%= p.fame %></span>
              <% if (p.common_tags) { %><span class="tag-mini"><%= p.common_tags %> shared tag<%= p.common_tags === 1 ? '' : 's' %></span><% } %>
            </p>
          </div>
        </a>
      </article>
    <% }) %>
  </section>
<% } %>
<%- include('partials/foot') %>
